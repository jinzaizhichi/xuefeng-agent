# 雪峰Agent 配置文件
# 复制此文件为 .env，填入你的 API Key

# ── 方式一：手动指定（推荐） ──
LLM_API_KEY=sk-your-api-key-here
LLM_BASE_URL=https://api.deepseek.com
LLM_MODEL=deepseek-chat

# ── 方式二：用 LLM_PROVIDER 快捷切换（不需要填 BASE_URL 和 MODEL）──
# LLM_PROVIDER=deepseek   # DeepSeek（推荐，性价比高）
# LLM_PROVIDER=qwen       # 通义千问
# LLM_PROVIDER=glm        # 智谱 GLM-4
# LLM_PROVIDER=moonshot   # Moonshot
# LLM_PROVIDER=openai     # GPT-4o
# LLM_PROVIDER=ollama     # 本地模型（免费离线）
